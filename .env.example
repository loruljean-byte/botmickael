# ====== Discord OAuth2 ======
DISCORD_CLIENT_ID=xxxxxxxxxxxxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxx
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback

# ====== Discord Bot ======
DISCORD_BOT_TOKEN=xxxxxxxxxxxxxxxxx

# ====== Serveur Discord à vérifier ======
# ID du serveur de ton accompagnement (clic droit sur le serveur -> Copier l'ID)
GUILD_ID=xxxxxxxxxxxxxxxxx

# ====== Admins (reçoivent les MP du bot) ======
# Tes IDs Discord (toi + ton associé), séparés par une virgule
ADMIN_DISCORD_IDS=111111111111111111,222222222222222222

# ====== Session ======
# Change-moi par une longue chaîne random (ex: openssl rand -hex 32)
SESSION_SECRET=change_moi_avec_une_longue_chaine_aleatoire

# ====== Port ======
PORT=3000
